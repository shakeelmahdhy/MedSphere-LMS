# ============ Backend (Render) ============
# Supabase → Project Settings → Database → Connection string (URI)
# Use "Session" mode for long-running servers (Render). Use port 5432 URI.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Project Settings → API → service_role (secret — backend only, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional bucket names (create these as public buckets in Supabase Storage)
SUPABASE_COURSE_BUCKET=course-content
SUPABASE_PROFILE_BUCKET=profile-pictures

# Public URL of your FastAPI backend (used for local file fallback only)
PUBLIC_API_URL=https://your-app.onrender.com

# JWT secret for auth tokens
SECRET_KEY=change-me-to-a-long-random-string

# ============ Frontend (Vercel) ============
VITE_API_URL=https://your-app.onrender.com/api
